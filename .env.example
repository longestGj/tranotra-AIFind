# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Database Configuration
DATABASE_URL=sqlite:///./data/tranotra_leads.db

# Gemini API Configuration (REQUIRED)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Apollo.io Configuration (For Phase 2+)
APOLLO_API_KEY=your-apollo-api-key-here

# Hunter.io Configuration (For Phase 2+)
HUNTER_API_KEY=your-hunter-api-key-here

# Aliyun DirectMail Configuration (For Phase 2+)
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_SECRET=your-aliyun-secret
ALIYUN_FROM_EMAIL=noreply@example.com

# Logging Configuration
LOG_LEVEL=INFO
